# Public GitHub mirror ignore rules
# Generated by publish-github.py

# Runtime data
user_config/
backups/
server_log/
Product/

# Database / logs
*.db
*.sqlite
*.sqlite3
*.log
*.bak

# Secrets / local config
.env
.env.*
*.local
*.pem
*.key
*.crt
*.cert
*.p12
*.pfx

# Build outputs
bin/
dist/
web/node_modules/
web/.next/
web/out/
web/dist/
web/build/
web/coverage/
web/*.tsbuildinfo

# Plugin build artifacts and frontend dependencies
plugins/*/dist/
plugins/*/releases/
plugins/*/frontend/node_modules/
plugins/*/frontend/.next/
plugins/*/frontend/out/
plugins/*/frontend/dist/
plugins/*/frontend/build/
plugins/*/frontend/coverage/

# AI / local context
CLAUDE.md
AGENTS.md
.claude/
Docs/
Source/
Program/

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
